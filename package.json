{
  "name": "icewall",
  "version": "0.0.1",
  "description": "An auth server for Node.js and WinterTC-compatible platforms",
  "license": "Apache-2.0",
  "author": {
    "name": "Jumpei Ogawa",
    "url": "https://phanective.org"
  },
  "contributors": [
    {
      "name": "The better-auth contributors",
      "url": "https://github.com/better-auth/better-auth/graphs/contributors"
    }
  ],
  "keywords": [
    "authentication",
    "authorization",
    "auth"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "migrate": "pnpx @better-auth/cli migrate",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "clean": "git clean -dX --exclude=\"!.env\" --force",
    "refresh": "pnpm run clean && rm --force ./pnpm-lock.yaml && corepack up && pnpm install",
    "release": "npm publish --access public --non-interactive",
    "prepare": "pnpm approve-builds && svelte-kit sync"
  },
  "dependencies": {
    "@internationalized/date": "^3.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "better-auth": "workspace:*",
    "better-sqlite3": "^11.6.0",
    "bits-ui": "^0.21.16",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.18",
    "embla-carousel-svelte": "^8.5.1",
    "formsnap": "^1.0.1",
    "mode-watcher": "^0.4.1",
    "paneforge": "^0.0.6",
    "svelte-radix": "^2.0.1",
    "svelte-sonner": "^0.3.28",
    "sveltekit-superforms": "^2.21.1",
    "tailwind-merge": "^2.5.5",
    "tailwind-variants": "^0.2.1",
    "vaul-svelte": "^0.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@better-auth/cli": "workspace:*",
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/typography": "^0.5.15",
    "autoprefixer": "^10.4.20",
    "svelte": "^5.22.5",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.2.1"
  },
  "engines": {
    "node": "20.x || >=22.x",
    "pnpm": ">=10.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  },
  "packageManager": "pnpm@9.15.0"
}
